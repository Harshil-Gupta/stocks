# Quant Agent Trader Configuration
# Copy this file to .env and update with your paths

# ============================================================================
# REQUIRED: Holdings Directory (mandatory)
# ============================================================================
# Directory containing your holdings CSV files exported from broker
# Add/remove/update CSV files in this directory as needed
HOLDINGS_DIR=C:\Users\Harshil\Desktop\holdings

# ============================================================================
# OPTIONAL: Trade History CSV
# ============================================================================
# Export trade history from broker (if available)
TRADES_CSV_PATH=C:\Users\Harshil\Desktop\trades.csv

# ============================================================================
# API Keys (optional - system works without these using mock data)
# ============================================================================
# POLYGON_API_KEY=your_polygon_key
# ALPHA_VANTAGE_KEY=your_alpha_vantage_key
# UPSTOX_API_KEY=your_upstox_api_key
# UPSTOX_API_SECRET_KEY=your_upstox_api_secret_key
# UPSTOX_ACCESS_TOKEN=your_upstox_access_token